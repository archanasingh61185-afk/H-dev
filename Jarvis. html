  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .heading-font { font-family: 'Space Grotesk', sans-serif; }
    
    .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 99px; }
    
    /* Standard State Orb */
    .orb-wrapper {
      position: relative;
      width: 170px;
      height: 170px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.5s ease-in-out;
    }
    .liquid-boundary {
      position: absolute;
      inset: 0;
      background: linear-gradient(45deg, #1d4ed8, #2563eb, #3b82f6);
      border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
      animation: morphingLiquid 8s infinite ease-in-out;
      filter: blur(1px);
      box-shadow: 0 0 35px rgba(37, 99, 235, 0.5);
      transition: all 0.5s ease-in-out;
    }
    .white-core {
      position: absolute;
      width: 80px;
      height: 80px;
      background: radial-gradient(circle, #ffffff 0%, #f1f5f9 60%, #cbd5e1 100%);
      border-radius: 50%;
      box-shadow: 0 0 25px rgba(255, 255, 255, 0.9);
      z-index: 10;
      transition: all 0.5s ease-in-out;
    }
    
    /* Immersive LIVE Mode Active UI Overrides */
    .live-active .liquid-boundary {
      background: linear-gradient(135deg, #06b6d4, #0ea5e9, #3b82f6, #6366f1);
      animation: morphingLiquid 3s infinite linear;
      box-shadow: 0 0 60px rgba(6, 182, 212, 0.8), 0 0 100px rgba(99, 102, 241, 0.4);
    }
    .live-active .white-core {
      width: 90px;
      height: 90px;
      background: radial-gradient(circle, #ffffff 0%, #e0f2fe 40%, #bae6fd 100%);
      box-shadow: 0 0 40px rgba(255, 255, 255, 1), inset 0 0 15px rgba(14, 165, 233, 0.4);
      animation: pulseCoreLive 1.5s infinite ease-in-out;
    }
    .live-active .live-ambient-glow {
      background: radial-gradient(circle at center, rgba(6, 182, 212, 0.2) 0%, rgba(99, 102, 241, 0.05) 50%, transparent 75%);
    }

    /* Live Mode Equalizer Wave Visualization */
    .voice-wave-bar {
      width: 4px;
      height: 12px;
      background-color: #06b6d4;
      border-radius: 99px;
      animation: wavePulse 1.2s infinite ease-in-out;
      display: none;
    }
    .live-active .voice-wave-bar { display: block; }
    .voice-wave-bar:nth-child(2) { animation-delay: 0.15s; height: 22px; }
    .voice-wave-bar:nth-child(3) { animation-delay: 0.3s; height: 32px; background-color: #3b82f6; }
    .voice-wave-bar:nth-child(4) { animation-delay: 0.45s; height: 18px; }
    .voice-wave-bar:nth-child(5) { animation-delay: 0.6s; height: 26px; background-color: #6366f1; }

    @keyframes morphingLiquid {
      0% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; transform: rotate(0deg); }
      50% { border-radius: 70% 30% 52% 48% / 60% 40% 60% 40%; transform: rotate(180deg); }
      100% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; transform: rotate(360deg); }
    }
    @keyframes pulseCoreLive {
      0%, 100% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.12); filter: brightness(1.25); }
    }
    @keyframes wavePulse {
      0%, 100% { transform: scaleY(1); }
      50% { transform: scaleY(2.2); }
    }

    .typing-dot { animation: typing 1.4s infinite ease-in-out both; }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
  </style>
